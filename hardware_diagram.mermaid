---
title: "Lancha Robot V1 — Full Hardware Architecture"
---
flowchart TB

    %% ──────────────────────────────────────────────
    %% STYLES
    %% ──────────────────────────────────────────────
    classDef hull fill:#2c3e50,color:#ecf0f1,stroke:#1a252f,stroke-width:2px
    classDef frame fill:#34495e,color:#ecf0f1,stroke:#2c3e50,stroke-width:2px
    classDef propulsion fill:#e67e22,color:#fff,stroke:#d35400,stroke-width:2px
    classDef arm fill:#9b59b6,color:#fff,stroke:#8e44ad,stroke-width:2px
    classDef electronics fill:#e74c3c,color:#fff,stroke:#c0392b,stroke-width:2px
    classDef printed fill:#2ecc71,color:#fff,stroke:#27ae60,stroke-width:2px
    classDef cargo fill:#f39c12,color:#fff,stroke:#e67e22,stroke-width:2px
    classDef sensor fill:#3498db,color:#fff,stroke:#2980b9,stroke-width:2px
    classDef operator fill:#1abc9c,color:#fff,stroke:#16a085,stroke-width:2px
    classDef water fill:#85C1E9,color:#1a5276,stroke:#2980b9,stroke-width:2px,stroke-dasharray: 5 5

    %% ══════════════════════════════════════════════
    %% TOP-LEVEL LAYOUT
    %% ══════════════════════════════════════════════

    subgraph ROBOT["Lancha Robot V1 — Catamaran Surface Vessel"]
        direction TB

        %% ──────────────────────────────────────
        %% HULL & FLOTATION
        %% ──────────────────────────────────────
        subgraph HULL["1. Hull & Flotation Platform"]
            direction TB

            subgraph PONTOONS["Twin Pontoons (horizontal, parallel, 1.0-1.2m apart c-to-c)"]
                direction LR
                P_PORT["Port Pontoon\n200L HDPE Drum\n~200kg buoyancy\nsilicone-sealed bungs\nspray foam base (5cm)"]
                P_STAR["Starboard Pontoon\n200L HDPE Drum\n~200kg buoyancy\nsilicone-sealed bungs\nspray foam base (5cm)"]
            end

            subgraph FRAME_DECK["Frame & Deck"]
                direction TB
                FRAME["Rectangular Frame\n1.5m L x 1.2m W\n1in sq aluminum tube\nor 1.5in PVC pipe"]
                DECK["Deck Surface\n12mm marine plywood\nor HDPE sheet\n(flat mounting platform)"]
                SADDLES["Pontoon Saddle Clamps\n4-6x 3D-printed PETG\n+ U-bolts + rubber padding"]

                FRAME --- DECK
                FRAME --- SADDLES
            end

            subgraph DEFLECTORS["Weed Deflectors (front of each pontoon)"]
                direction LR
                DEF_L["Port V-Deflector\n2x 50cm PVC pipes\n30 deg angle, pipe clamps"]
                DEF_R["Starboard V-Deflector\n2x 50cm PVC pipes\n30 deg angle, pipe clamps"]
            end

            SADDLES -->|"U-bolts mount to"| PONTOONS
            DEF_L -->|"clamps to"| P_PORT
            DEF_R -->|"clamps to"| P_STAR
        end

        %% ──────────────────────────────────────
        %% PROPULSION (STERN)
        %% ──────────────────────────────────────
        subgraph PROPULSION["2. Propulsion System (stern of each pontoon)"]
            direction TB

            subgraph PROP_PORT["Port Drive Unit"]
                direction TB
                POD_L["Motor Pod (3D-printed PETG)\nangled 5-10 deg down\nlip seal on shaft"]
                MOT_L["775 Brushless Motor\n12V / ~150W / ~3000RPM"]
                PROP_L["Propeller (3D-printed PETG)\n3-blade, 80mm dia\nswept-back, 100% infill"]
                GUARD_L["Weed Guard (3D-printed PETG)\ncylindrical shroud\ncross-bar grid, 2cm spacing"]

                POD_L --- MOT_L
                MOT_L -->|"shaft + coupler"| PROP_L
                PROP_L --- GUARD_L
            end

            subgraph PROP_STAR["Starboard Drive Unit"]
                direction TB
                POD_R["Motor Pod (3D-printed PETG)\nangled 5-10 deg down\nlip seal on shaft"]
                MOT_R["775 Brushless Motor\n12V / ~150W / ~3000RPM"]
                PROP_R["Propeller (3D-printed PETG)\n3-blade, 80mm dia\nswept-back, 100% infill"]
                GUARD_R["Weed Guard (3D-printed PETG)\ncylindrical shroud\ncross-bar grid, 2cm spacing"]

                POD_R --- MOT_R
                MOT_R -->|"shaft + coupler"| PROP_R
                PROP_R --- GUARD_R
            end
        end

        %% ──────────────────────────────────────
        %% HYDRAULIC ARM (FRONT)
        %% ──────────────────────────────────────
        subgraph ARM["3. Hydraulic Robotic Arm — 3-DOF (front of deck, slightly off-center)"]
            direction TB

            subgraph ARM_BASE["Base Assembly"]
                direction TB
                BASE_POST["Vertical Post\npipe flange bolted to deck"]
                BEARING["Thrust / Lazy Susan Bearing\n(rotation pivot)"]
                BASE_POST --- BEARING
            end

            subgraph ARM_BOOM["Boom Structure"]
                direction LR
                BOOM["Main Boom\n~80cm long\n1.5in sq aluminum tube\nor 1in schedule-40 steel"]
                PIVOT["Shoulder Lift Pivot\nhinge, 15cm above base"]
                BOOM --- PIVOT
            end

            subgraph ARM_CYLINDERS["Hydraulic Cylinders (double-acting, 20mm bore)"]
                direction TB
                CYL1["Cylinder 1: Lift/Lower\nstroke 150-200mm\nmounted at shoulder"]
                CYL2["Cylinder 2: Rotate/Swivel\nstroke 100-150mm\nlever arm at base"]
                CYL3["Cylinder 3: Gripper\nstroke 50-100mm\nmounted on claw"]
            end

            subgraph GRIPPER["Gripper / Claw (3D-printed)"]
                direction TB
                GRIP_FRAME["Gripper Frame\nPETG, 100% infill"]
                FINGER_L["Finger Left\n15cm long x 5cm wide\nPETG + TPU rubber pad"]
                FINGER_R["Finger Right\n15cm long x 5cm wide\nPETG + TPU rubber pad"]
                LINKAGE["Parallel Linkage\ndriven by Cylinder 3\n20-25cm max opening"]
                DRAIN["Drainage Slots\nin fingers and frame"]

                GRIP_FRAME --- FINGER_L
                GRIP_FRAME --- FINGER_R
                GRIP_FRAME --- LINKAGE
                GRIP_FRAME --- DRAIN
                LINKAGE ---|"actuated by"| CYL3
            end

            subgraph HOSE_ROUTING["Hydraulic Hose Routing"]
                HOSES["6x Nylon Hoses (6mm / 1/4in)\n2 per cylinder (extend + retract)\nbundled with zip ties along boom\nslack loop at rotation joint\npush-fit connectors"]
            end

            BEARING -->|"supports rotation of"| ARM_BOOM
            PIVOT -->|"hinge for"| CYL1
            CYL2 -->|"lever pushes"| BEARING
            BOOM -->|"end effector"| GRIPPER
            HOSES -->|"connects valves to"| ARM_CYLINDERS
        end

        %% ──────────────────────────────────────
        %% ELECTRONICS BOX (CENTER OF DECK)
        %% ──────────────────────────────────────
        subgraph EBOX["4. Sealed Electronics Box (center deck)"]
            direction TB
            BOX_DESC["Airtight Container (~10L)\nsnap-lock rubber gasket lid\nor surplus ammo can\nsilica gel packets inside"]

            subgraph EBOX_POWER["Power System"]
                BATTERY["12V LiFePO4 Battery\n20-30Ah / 240-360Wh"]
                FUSE_B["25A Fuse/Breaker"]
                BUS_B["12V Terminal Strip"]
                BUCK_B["12V-to-5V Buck Converter"]
                BATTERY --- FUSE_B --- BUS_B --- BUCK_B
            end

            subgraph EBOX_CONTROL["Control Electronics"]
                RC_RX["RC Receiver\nFlySky FS-iA10B\n2.4GHz / 10ch"]
                ESC_LB["ESC Left (30A)"]
                ESC_RB["ESC Right (30A)"]
            end

            subgraph EBOX_HYDRAULIC["Hydraulic Power Unit"]
                H_PUMP["12V DC Gear Pump\n1.5-2.0 GPM"]
                H_TANK["Reservoir (1-2L)\nbiodegradable fluid"]
                H_V1["Solenoid Valve V1\n4-way 3-pos (Lift)"]
                H_V2["Solenoid Valve V2\n4-way 3-pos (Rotate)"]
                H_V3["Solenoid Valve V3\n4-way 3-pos (Gripper)"]
                H_PUMP <--> H_TANK
            end

            subgraph EBOX_VIDEO["Video Transmitter"]
                VTX_B["5.8GHz VTX\n600mW-1W\n(e.g. AKK X2 Ultimate)"]
            end

            subgraph GLANDS["Cable Glands (PG7/PG9/PG13.5, silicone sealed)"]
                direction LR
                G_MOTOR["2x Motor Power"]
                G_HOSE["6x Hydraulic Hoses"]
                G_CAM["1x Camera Power/Video"]
                G_ANT["2x Antenna Coax"]
                G_SW["1x Main Switch"]
            end
        end

        %% ──────────────────────────────────────
        %% MAST & SENSORS (TOP)
        %% ──────────────────────────────────────
        subgraph MAST["5. Antenna & Camera Mast (~50cm PVC, front deck)"]
            direction LR
            MAST_POST["Vertical PVC Mast\nmounted on deck"]
            CAM_B["FPV Camera\n1200TVL mini\n(e.g. RunCam Phoenix 2)\nfront-facing, angled down"]
            ANT_RC_B["RC Antenna\n2.4GHz quarter-wave\n(mounted at top)"]
            ANT_VTX_B["VTX Antenna\n5.8GHz Pagoda/Cloverleaf\n(mounted at top)"]
            BRACKET["3D-printed Mount Bracket\nadjustable angle"]

            MAST_POST --- BRACKET
            BRACKET --- CAM_B
            BRACKET --- ANT_RC_B
            BRACKET --- ANT_VTX_B
        end

        %% ──────────────────────────────────────
        %% CARGO (CENTER-AFT)
        %% ──────────────────────────────────────
        subgraph CARGO["6. Cargo Container (center-aft deck)"]
            BASKET["Plastic Crate / Laundry Basket\n~60L-80L capacity\n60cm x 40cm x 35cm\ndrainage holes\nbolted/zip-tied to deck\nholds ~50 plants / 30kg max"]
        end
    end

    %% ══════════════════════════════════════════════
    %% OPERATING ENVIRONMENT
    %% ══════════════════════════════════════════════
    subgraph ENV["Operating Environment"]
        direction LR
        WATER["Swampy Reservoir\nheavy surface vegetation\nlechuguilla plants"]
    end

    %% ══════════════════════════════════════════════
    %% OPERATOR
    %% ══════════════════════════════════════════════
    subgraph OPERATOR["Operator Station (shore, up to 2km)"]
        direction TB
        TX_OP["RC Transmitter\nFlySky FS-i6X\n2.4GHz / 10ch"]
        MON_OP["FPV Monitor 7in\nor EV800D Goggles\nbuilt-in 5.8GHz RX"]

        subgraph CONTROLS["Control Mapping"]
            direction TB
            C1["Left Stick Vert → Left Motor"]
            C2["Right Stick Vert → Right Motor"]
            C3["Left Stick Horiz → Arm Lift"]
            C4["Right Stick Horiz → Arm Rotate"]
            C5["SWA Switch → Gripper"]
            C6["VRA Knob → Camera Tilt (future)"]
        end
    end

    %% ══════════════════════════════════════════════
    %% CROSS-SUBSYSTEM CONNECTIONS
    %% ══════════════════════════════════════════════

    %% Physical mounting
    HULL -->|"supports"| PROPULSION
    HULL -->|"supports"| ARM
    HULL -->|"supports"| EBOX
    HULL -->|"supports"| MAST
    HULL -->|"supports"| CARGO

    %% Propulsion at stern
    POD_L -->|"bolts to stern of"| P_PORT
    POD_R -->|"bolts to stern of"| P_STAR

    %% Electronics to propulsion
    ESC_LB -->|"power cable\nthrough gland"| MOT_L
    ESC_RB -->|"power cable\nthrough gland"| MOT_R

    %% Electronics to arm
    H_V1 -->|"2x hoses\nthrough glands"| CYL1
    H_V2 -->|"2x hoses\nthrough glands"| CYL2
    H_V3 -->|"2x hoses\nthrough glands"| CYL3

    %% Electronics to mast
    VTX_B -->|"coax through gland"| ANT_VTX_B
    RC_RX -->|"coax through gland"| ANT_RC_B
    VTX_B -->|"video feed"| CAM_B

    %% RC signals
    RC_RX -.->|"PWM CH1-CH2"| ESC_LB
    RC_RX -.->|"PWM CH1-CH2"| ESC_RB
    RC_RX -.->|"PWM CH3-CH5"| H_V1
    RC_RX -.->|"PWM CH3-CH5"| H_V2
    RC_RX -.->|"PWM CH3-CH5"| H_V3

    %% Robot in environment
    ROBOT -->|"operates in"| ENV

    %% Operator links
    TX_OP -.->|"2.4GHz RC\n~1.5-2km"| ANT_RC_B
    ANT_VTX_B -.->|"5.8GHz video\n~2km+"| MON_OP

    %% ── APPLY STYLES ──
    class P_PORT,P_STAR hull
    class FRAME,DECK,SADDLES,DEF_L,DEF_R frame
    class POD_L,MOT_L,PROP_L,GUARD_L,POD_R,MOT_R,PROP_R,GUARD_R propulsion
    class BASE_POST,BEARING,BOOM,PIVOT,CYL1,CYL2,CYL3,HOSES arm
    class GRIP_FRAME,FINGER_L,FINGER_R,LINKAGE,DRAIN printed
    class BATTERY,FUSE_B,BUS_B,BUCK_B,BOX_DESC electronics
    class RC_RX,ESC_LB,ESC_RB electronics
    class H_PUMP,H_TANK,H_V1,H_V2,H_V3 arm
    class VTX_B,CAM_B,ANT_RC_B,ANT_VTX_B sensor
    class MAST_POST,BRACKET sensor
    class BASKET cargo
    class TX_OP,MON_OP,C1,C2,C3,C4,C5,C6 operator
    class WATER water
